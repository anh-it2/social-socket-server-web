# Must match social-platform-be JWT_SECRET — socket server only verifies.
JWT_SECRET=change-me-in-production

# Exact Next client origin (no trailing slash). Required for credentialed CORS.
CLIENT_ORIGIN=http://localhost:3000

PORT=3002

# SAME Postgres that social-platform-be owns + migrates. This server only
# `prisma generate`s a client and reads/writes rows — never `prisma migrate`.
DATABASE_URL="postgresql://spbe:spbe_password@localhost:5432/spbe?schema=public"
